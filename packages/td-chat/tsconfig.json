{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"],
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "module": "esnext",
    "rootDir": "../../",
    "moduleResolution": "bundler",
    "baseUrl": "../../",
    "resolveJsonModule": true,
    "allowJs": true,
    "declaration": true,
    "outDir": "./es",
    "removeComments": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "types": ["vue"]
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "lib",
    "esm",
    "es",
    "**/*.d.ts"
  ]
}
